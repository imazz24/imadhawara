# =============================================================================
# NexusVision Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values
# Never commit .env.local to version control
# =============================================================================

# -----------------------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------------------

# Application URL (used for generating links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Application name (displayed in UI)
NEXT_PUBLIC_APP_NAME=NexusVision

# -----------------------------------------------------------------------------
# API Configuration (for future backend integration)
# -----------------------------------------------------------------------------

# Backend API URL
# NEXT_PUBLIC_API_URL=http://localhost:8000/api

# API Key for authentication
# API_KEY=your-api-key-here

# -----------------------------------------------------------------------------
# AI Model Configuration
# -----------------------------------------------------------------------------

# YOLO model endpoint (for real AI detection)
# YOLO_API_ENDPOINT=http://localhost:5000/detect

# Model confidence threshold (0.0 - 1.0)
# NEXT_PUBLIC_CONFIDENCE_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Camera Configuration
# -----------------------------------------------------------------------------

# RTSP stream URLs (comma-separated for multiple cameras)
# CAMERA_STREAMS=rtsp://camera1:554/stream,rtsp://camera2:554/stream

# WebSocket URL for real-time camera feeds
# NEXT_PUBLIC_WS_URL=ws://localhost:8080

# -----------------------------------------------------------------------------
# Analytics & Monitoring (Optional)
# -----------------------------------------------------------------------------

# Sentry DSN for error tracking
# SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# Analytics ID
# NEXT_PUBLIC_ANALYTICS_ID=UA-XXXXXXXXX-X

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------

# Enable demo/simulation mode (true for demo, false for production)
NEXT_PUBLIC_DEMO_MODE=true

# Enable debug logging
# NEXT_PUBLIC_DEBUG=false